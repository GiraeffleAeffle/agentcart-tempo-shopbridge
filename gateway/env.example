AGENTCART_BIND=0.0.0.0
AGENTCART_PORT=8099
AGENTCART_PUBLIC_URL=http://home-server.local:8099
AGENTCART_TIMEZONE=Europe/Berlin
AGENTCART_TOKEN=replace-with-random-agentcart-token
AGENTCART_DATA_DIR=/data
AGENTCART_DEFAULT_SHIP_COUNTRY=DE
AGENTCART_DEFAULT_SHIP_POSTAL_CODE=10115

# Payment provider.
# demo: HTTP 402 Payment-auth-shaped flow with no real funds.
# tempo_mpp: reserved fail-closed mode for real Tempo MPP integration.
# agentcash_x402: reserved fail-closed mode for real AgentCash/x402 proof.
AGENTCART_PAYMENT_PROVIDER=demo
AGENTCART_TEMPO_MPP_ENDPOINT=

# Optional Tempo MPP value-transfer proof after approval/checkout. This is
# separate from the default demo checkout provider. The easiest hackathon path
# is testnet: create/fund an mppx account, run scripts/mpp-smoke-server.mjs, and
# point AGENTCART_TEMPO_MPP_PROOF_URL at its /paid endpoint.
AGENTCART_TEMPO_MPP_PROOF_URL=
AGENTCART_TEMPO_MPP_COMMAND="npx mppx"
AGENTCART_TEMPO_MPP_NETWORK=testnet
AGENTCART_TEMPO_MPP_ACCOUNT=agentcart-test
AGENTCART_TEMPO_MPP_PROOF_REQUIRED=false
AGENTCART_TEMPO_MPP_TIMEOUT_SECONDS=90
AGENTCART_TEMPO_RECIPIENT_ADDRESS=

# Optional real-value proof after approval/checkout. This is separate from the
# default demo checkout provider: it can call a tiny paid AgentCash/x402 endpoint
# and attach the resulting proof to PaymentReceipt.external_value_proof.
AGENTCART_AGENTCASH_PROOF_URL=
AGENTCART_AGENTCASH_COMMAND="npx -y agentcash@latest fetch"
AGENTCART_AGENTCASH_PROOF_REQUIRED=false
AGENTCART_AGENTCASH_TIMEOUT_SECONDS=60

# Optional policy override. If unset, AgentCart uses the conservative default
# in config/household_policy.example.json.
AGENTCART_POLICY_PATH=/app/config/household_policy.example.json

# WooCommerce merchant adapter.
# mock: local Woo-style tea products and mock Woo order refs.
# plugin: use the AgentCart ShopBridge WooCommerce plugin for catalog, quote,
# and merchant order creation.
# rest: read products and create paid orders through a real opt-in Woo shop's
# REST API after AgentCart approval and HTTP 402 payment-auth checkout.
# disabled: hide the Woo adapter.
WOOCOMMERCE_MODE=mock
WOOCOMMERCE_BASE_URL=https://shop.example.com
WOOCOMMERCE_CONSUMER_KEY=ck_replace_with_woocommerce_key
WOOCOMMERCE_CONSUMER_SECRET=cs_replace_with_woocommerce_secret
WOOCOMMERCE_AGENTCART_TOKEN=replace-with-agentcart-shopbridge-token
WOOCOMMERCE_MERCHANT_ID=woocommerce-demo-tea
WOOCOMMERCE_MERCHANT_NAME=Woo Demo Tea Shop

# Optional merchant registry alpha. This lets AgentCart discover additional
# ShopBridge merchants from a signed off-chain JSON feed before a future
# onchain registry exists.
AGENTCART_MERCHANT_REGISTRY_PATH=
AGENTCART_MERCHANT_REGISTRY_URL=
AGENTCART_MERCHANT_REGISTRY_HMAC_SECRET=
AGENTCART_REQUIRE_VERIFIED_REGISTRY=true
AGENTCART_MERCHANT_REGISTRY_MAX_AGE_DAYS=180
AGENTCART_REGISTRY_MONITOR_INTERVAL_SECONDS=0
AGENTCART_REGISTRY_MONITOR_HISTORY_LIMIT=50
AGENTCART_REGISTRY_ALERT_WEBHOOK_URL=
AGENTCART_REGISTRY_ALERT_WEBHOOK_TOKEN=
AGENTCART_REGISTRY_ALERT_HOMEASSISTANT_ENABLED=false
AGENTCART_REGISTRY_ALERT_EMAIL_TO=
AGENTCART_REGISTRY_ALERT_EMAIL_FROM=
AGENTCART_REGISTRY_ALERT_SMTP_HOST=
AGENTCART_REGISTRY_ALERT_SMTP_PORT=587
AGENTCART_REGISTRY_ALERT_SMTP_USERNAME=
AGENTCART_REGISTRY_ALERT_SMTP_PASSWORD=
AGENTCART_REGISTRY_ALERT_SMTP_STARTTLS=true
AGENTCART_REGISTRY_ALERT_MIN_SEVERITY=warning
AGENTCART_REGISTRY_ALERT_INCLUDE_RESOLVED=true
AGENTCART_VERIFIER_ALERT_WEBHOOK_URL=
AGENTCART_VERIFIER_ALERT_WEBHOOK_TOKEN=
AGENTCART_VERIFIER_ALERT_MIN_SEVERITY=warning
AGENTCART_VERIFIER_ALERT_THROTTLE_SECONDS=300
AGENTCART_OPS_EVENT_WEBHOOK_URL=
AGENTCART_OPS_EVENT_WEBHOOK_TOKEN=
AGENTCART_OPS_EVENT_HOMEASSISTANT_ENABLED=false
AGENTCART_OPS_EVENT_EMAIL_TO=
AGENTCART_OPS_EVENT_EMAIL_FROM=
AGENTCART_OPS_EVENT_SMTP_HOST=
AGENTCART_OPS_EVENT_SMTP_PORT=587
AGENTCART_OPS_EVENT_SMTP_USERNAME=
AGENTCART_OPS_EVENT_SMTP_PASSWORD=
AGENTCART_OPS_EVENT_SMTP_STARTTLS=true
AGENTCART_OPS_EVENT_MIN_SEVERITY=warning

# Optional Home Assistant approval notifications.
HOMEASSISTANT_URL=http://homeassistant.local:8123
HOMEASSISTANT_TOKEN=replace-with-dedicated-home-assistant-long-lived-token
HA_NOTIFY_SERVICES=notify.mobile_app_demo_phone,notify.mobile_app_partner_phone
HOMEASSISTANT_CALENDAR_ENTITY_ID=calendar.household_deliveries

# Optional read-only energy-surplus detection for the AgentWatt demo branch.
# These defaults match the current Solarbank / smart-meter Home Assistant names.
AGENTCART_ENERGY_SOLAR_POWER_ENTITY=sensor.solarbank_3_e2700_pro_solarleistung
AGENTCART_ENERGY_BATTERY_LEVEL_ENTITY=sensor.solarbank_3_e2700_pro_ladestand
AGENTCART_ENERGY_BATTERY_POWER_ENTITY=sensor.solarbank_3_e2700_pro_akkuleistung
AGENTCART_ENERGY_GRID_EXPORT_ENTITY=sensor.smart_meter_netzeinspeisung
AGENTCART_ENERGY_GRID_IMPORT_ENTITY=sensor.smart_meter_netzbezug
AGENTCART_ENERGY_HOUSE_OUTPUT_ENTITY=sensor.solarbank_3_e2700_pro_ac_hausabgabe
AGENTCART_ENERGY_MIN_EXPORT_W=100
AGENTCART_ENERGY_MIN_BATTERY_PERCENT=70

# Optional read-only delivery calendar feed for subscribing from household
# calendars. Treat the tokenized URL like a password.
AGENTCART_DELIVERY_CALENDAR_ENABLED=true
AGENTCART_DELIVERY_CALENDAR_TOKEN=replace-with-random-delivery-calendar-token

# Optional Vikunja task creation after a successful order.
VIKUNJA_API_URL=http://vikunja:3456/api/v1
VIKUNJA_WEB_URL=http://vikunja.local:3456
VIKUNJA_TOKEN=tk_replace_with_scoped_vikunja_api_token
VIKUNJA_PROJECT_ID=
