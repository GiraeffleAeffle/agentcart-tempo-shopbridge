# Production-shaped ShopBridge payment overlay.
#
# Apply this after deploy/home-server/.env.example, or copy these values into
# your real .env. Placeholder values validate only with
# scripts/check-production-payment-profile.py --allow-placeholders; real beta
# releases must replace every secret/profile/URL value.

WOOCOMMERCE_MODE=plugin

AGENTCART_CHECKOUT_MODE=external_verifier_only
AGENTCART_PAYMENT_VERIFIER_URL=https://verifier.example.com/stripe-mpp/verify
AGENTCART_PAYMENT_VERIFIER_TOKEN=replace-with-random-verifier-bearer-token

AGENTCART_VERIFIER_REPLAY_STORE_PATH=/data/verifier/replay-store.json
AGENTCART_VERIFIER_REQUIRE_DURABLE_REPLAY=true
AGENTCART_VERIFIER_REPLAY_LOCK_TIMEOUT_MS=5000
AGENTCART_VERIFIER_REPLAY_JOURNAL_PATH=/data/verifier/replay-journal.jsonl
AGENTCART_VERIFIER_REQUIRE_REPLAY_JOURNAL=false

AGENTCART_SIGNED_REQUEST_MODE=require_mutations
AGENTCART_SIGNED_REQUEST_SECRET=replace-with-random-shopbridge-hmac-secret
WOOCOMMERCE_SIGNED_REQUEST_SECRET=replace-with-random-shopbridge-hmac-secret
WOOCOMMERCE_SIGNED_REQUEST_SIGNER=agentcart-service
