COMPOSE_PROJECT_NAME=agentcart-home

AGENTCART_CONTEXT=../../gateway
HOUSEHOLD_OS_CONTEXT=../../household-os
WOO_DEMO_CONTEXT=../../demo/woocommerce

AGENTCART_PUBLIC_URL=http://localhost:8099
AGENTCART_HOST_PORT=8099
AGENTCART_TOKEN=replace-with-random-agentcart-token
AGENTCART_TIMEZONE=Europe/Berlin
AGENTCART_DEFAULT_SHIP_COUNTRY=DE
AGENTCART_DEFAULT_SHIP_POSTAL_CODE=15344
AGENTCART_DELIVERY_CALENDAR_ENABLED=true
AGENTCART_DELIVERY_CALENDAR_TOKEN=replace-with-random-calendar-token

HOUSEHOLD_OS_HOST_PORT=8088
HOUSEHOLD_OS_TOKEN=replace-with-random-household-token

POSTGRES_DB=vikunja
POSTGRES_USER=vikunja
POSTGRES_PASSWORD=replace-with-random-postgres-password
VIKUNJA_SERVICE_PUBLICURL=http://localhost:3456
VIKUNJA_WEB_URL=http://localhost:3456
VIKUNJA_HOST_PORT=3456
VIKUNJA_SERVICE_SECRET=replace-with-random-vikunja-secret
VIKUNJA_TOKEN=replace-with-vikunja-api-token-after-user-setup
VIKUNJA_PROJECT_ID=

HOMEASSISTANT_URL=http://homeassistant:8123
HOMEASSISTANT_TOKEN=replace-with-home-assistant-long-lived-token
HA_NOTIFY_SERVICES=
HOME_ASSISTANT_HOST_PORT=8123

OPENCLAW_GATEWAY_URL=
OPENCLAW_GATEWAY_TOKEN=

# Keep disabled unless you also start the woocommerce-demo profile. Set to
# plugin when running the bundled Woo demo or pointing at a real ShopBridge shop.
WOOCOMMERCE_MODE=disabled
WOOCOMMERCE_BASE_URL=http://woocommerce:80
WOOCOMMERCE_AGENTCART_TOKEN=replace-with-agentcart-shopbridge-token
WOOCOMMERCE_MERCHANT_ID=woocommerce-demo-shop
WOOCOMMERCE_MERCHANT_NAME=AgentCart Demo Shop

WOO_HOST_PORT=8098
WOO_DB_PASSWORD=replace-with-random-woo-db-password
WOO_ADMIN_USER=agentcart
WOO_ADMIN_PASSWORD=replace-with-random-woo-admin-password
WOO_ADMIN_EMAIL=merchant@example.com
