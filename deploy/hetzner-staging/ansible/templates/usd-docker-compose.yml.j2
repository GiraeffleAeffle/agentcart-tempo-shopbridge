services:
  db:
    image: mariadb:11
    restart: unless-stopped
    environment:
      MARIADB_DATABASE: wordpress
      MARIADB_USER: wordpress
      MARIADB_PASSWORD: ${STAGING_DB_PASSWORD}
      MARIADB_ROOT_PASSWORD: ${STAGING_DB_ROOT_PASSWORD}
    volumes:
      - db_data:/var/lib/mysql
    networks:
      default:
        aliases:
          - agentcart-usd-db

  wordpress:
    image: wordpress:php8.2-apache
    restart: unless-stopped
    depends_on:
      - db
      - verifier
    environment:
      WORDPRESS_DB_HOST: agentcart-usd-db:3306
      WORDPRESS_DB_USER: wordpress
      WORDPRESS_DB_PASSWORD: ${STAGING_DB_PASSWORD}
      WORDPRESS_DB_NAME: wordpress
      WORDPRESS_CONFIG_EXTRA: |
        define('AGENTCART_SHOPBRIDGE_TOKEN', getenv('AGENTCART_SHOPBRIDGE_TOKEN') ?: '');
        define('AGENTCART_MERCHANT_ID', getenv('AGENTCART_MERCHANT_ID') ?: 'agentcart-usd-staging-shop');
        define('AGENTCART_TEMPO_NETWORK', getenv('AGENTCART_TEMPO_NETWORK') ?: 'testnet');
        define('AGENTCART_TEMPO_RECIPIENT_ADDRESS', getenv('AGENTCART_TEMPO_RECIPIENT_ADDRESS') ?: '');
        define('AGENTCART_STRIPE_PROFILE_ID', getenv('AGENTCART_STRIPE_PROFILE_ID') ?: '');
        define('AGENTCART_PAYMENT_VERIFIER_URL', getenv('AGENTCART_PAYMENT_VERIFIER_URL') ?: '');
        define('AGENTCART_PAYMENT_VERIFIER_TOKEN', getenv('AGENTCART_PAYMENT_VERIFIER_TOKEN') ?: '');
        define('AGENTCART_CHECKOUT_MODE', getenv('AGENTCART_CHECKOUT_MODE') ?: 'external_verifier_only');
        define('AGENTCART_SIGNED_REQUEST_MODE', getenv('AGENTCART_SIGNED_REQUEST_MODE') ?: 'off');
        define('AGENTCART_SIGNED_REQUEST_SECRET', getenv('AGENTCART_SIGNED_REQUEST_SECRET') ?: '');
        define('AGENTCART_SUPPORT_EMAIL', getenv('AGENTCART_SUPPORT_EMAIL') ?: '');
        define('AGENTCART_RETURNS_URL', getenv('AGENTCART_RETURNS_URL') ?: '');
        define('AGENTCART_SUBSTITUTION_POLICY', getenv('AGENTCART_SUBSTITUTION_POLICY') ?: 'approval_required');
        define('AGENTCART_CANCELLATION_WINDOW_MINUTES', getenv('AGENTCART_CANCELLATION_WINDOW_MINUTES') ?: 30);
      AGENTCART_SHOPBRIDGE_TOKEN: ${STAGING_SHOPBRIDGE_TOKEN}
      AGENTCART_MERCHANT_ID: ${STAGING_MERCHANT_ID}
      AGENTCART_SUPPORT_EMAIL: ${STAGING_WOO_ADMIN_EMAIL}
      AGENTCART_RETURNS_URL: https://${STAGING_DOMAIN}/returns
      AGENTCART_SUBSTITUTION_POLICY: approval_required
      AGENTCART_CANCELLATION_WINDOW_MINUTES: "30"
      AGENTCART_TEMPO_NETWORK: testnet
      AGENTCART_TEMPO_RECIPIENT_ADDRESS: ${STAGING_TEMPO_RECIPIENT_ADDRESS}
      AGENTCART_STRIPE_PROFILE_ID: ""
      AGENTCART_PAYMENT_VERIFIER_URL: http://agentcart-usd-verifier:4260/agentcart/verify
      AGENTCART_PAYMENT_VERIFIER_TOKEN: ${STAGING_PAYMENT_VERIFIER_TOKEN}
      AGENTCART_CHECKOUT_MODE: external_verifier_only
      AGENTCART_SIGNED_REQUEST_MODE: off
      AGENTCART_SIGNED_REQUEST_SECRET: ""
    volumes:
      - wordpress_data:/var/www/html
      - ./agentcart-shopbridge:/var/www/html/wp-content/plugins/agentcart-shopbridge:ro
    networks:
      default:
      caddy_proxy:

  verifier:
    image: node:22-alpine
    restart: unless-stopped
    working_dir: /app
    environment:
      STRIPE_MPP_VERIFIER_BIND: 0.0.0.0
      STRIPE_MPP_VERIFIER_PORT: "4260"
      STRIPE_SANDBOX_SECRET_KEY: ${STAGING_STRIPE_SANDBOX_SECRET_KEY}
      STRIPE_PROFILE_ID: ${STAGING_STRIPE_PROFILE_ID}
      MPP_SECRET_KEY: ${STAGING_MPP_SECRET_KEY}
      AGENTCART_PAYMENT_VERIFIER_TOKEN: ${STAGING_PAYMENT_VERIFIER_TOKEN}
      AGENTCART_VERIFIER_REPLAY_STORE_PATH: /data/replay-store.json
      AGENTCART_VERIFIER_REPLAY_JOURNAL_PATH: /data/replay-journal.jsonl
      AGENTCART_VERIFIER_REQUIRE_DURABLE_REPLAY: "1"
      AGENTCART_VERIFIER_REQUIRE_REPLAY_JOURNAL: "1"
      AGENTCART_TEMPO_SETTLEMENT_MODE: ${STAGING_TEMPO_SETTLEMENT_MODE:-disabled}
      AGENTCART_TEMPO_SETTLEMENT_RPC_URL: ${STAGING_TEMPO_SETTLEMENT_RPC_URL:-}
      AGENTCART_TEMPO_SETTLEMENT_ASSET: ${STAGING_TEMPO_SETTLEMENT_ASSET:-pathUSD}
      AGENTCART_TEMPO_SETTLEMENT_TOKEN_ADDRESS: ${STAGING_TEMPO_SETTLEMENT_TOKEN_ADDRESS:-0x20c0000000000000000000000000000000000000}
      AGENTCART_TEMPO_REFUND_MODE: ${STAGING_TEMPO_REFUND_MODE:-disabled}
      AGENTCART_TEMPO_REFUND_PRIVATE_KEY: ${STAGING_TEMPO_REFUND_PRIVATE_KEY:-}
      AGENTCART_TEMPO_REFUND_ASSET: ${STAGING_TEMPO_REFUND_ASSET:-pathUSD}
      AGENTCART_TEMPO_REFUND_TOKEN_ADDRESS: ${STAGING_TEMPO_REFUND_TOKEN_ADDRESS:-0x20c0000000000000000000000000000000000000}
    command: sh -c "npm ci --omit=dev --cache /tmp/npm-cache && node scripts/stripe-mpp-verifier.mjs"
    volumes:
      - ./verifier:/app
      - verifier_data:/data
    networks:
      default:
        aliases:
          - agentcart-usd-verifier
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:4260/health | grep '\"ok\": true'"]
      interval: 15s
      timeout: 5s
      retries: 12

  wpcli:
    image: wordpress:cli-php8.2
    user: "0:0"
    depends_on:
      - wordpress
      - db
    environment:
      WORDPRESS_DB_HOST: agentcart-usd-db:3306
      WORDPRESS_DB_USER: wordpress
      WORDPRESS_DB_PASSWORD: ${STAGING_DB_PASSWORD}
      WORDPRESS_DB_NAME: wordpress
      WOO_PUBLIC_URL: https://${STAGING_DOMAIN}
      WOO_ADMIN_USER: ${STAGING_WOO_ADMIN_USER}
      WOO_ADMIN_PASSWORD: ${STAGING_WOO_ADMIN_PASSWORD}
      WOO_ADMIN_EMAIL: ${STAGING_WOO_ADMIN_EMAIL}
      AGENTCART_WOO_MARKET_PROFILE: ${STAGING_WOO_MARKET_PROFILE:-tempo-usd-staging}
      AGENTCART_WOO_SHOP_TITLE: ${STAGING_WOO_SHOP_TITLE:-AgentCart USD Test Shop}
      AGENTCART_SHOPBRIDGE_TOKEN: ${STAGING_SHOPBRIDGE_TOKEN}
      AGENTCART_MERCHANT_ID: ${STAGING_MERCHANT_ID}
      AGENTCART_RETURNS_URL: https://${STAGING_DOMAIN}/returns
      AGENTCART_WOO_VARIANCE_PROFILE: baseline-eu-tax-shipping
      AGENTCART_SUPPRESS_DEMO_CREDENTIAL_ECHO: "1"
      AGENTCART_TEMPO_NETWORK: testnet
      AGENTCART_TEMPO_RECIPIENT_ADDRESS: ${STAGING_TEMPO_RECIPIENT_ADDRESS}
      AGENTCART_PAYMENT_VERIFIER_URL: http://agentcart-usd-verifier:4260/agentcart/verify
      AGENTCART_PAYMENT_VERIFIER_TOKEN: ${STAGING_PAYMENT_VERIFIER_TOKEN}
      AGENTCART_CHECKOUT_MODE: external_verifier_only
    volumes:
      - wordpress_data:/var/www/html
      - ./agentcart-shopbridge:/var/www/html/wp-content/plugins/agentcart-shopbridge:ro
      - ./seed-products.sh:/seed-products.sh:ro
    entrypoint: ["bash", "/seed-products.sh"]

networks:
  caddy_proxy:
    external: true
    name: {{ caddy_proxy_network }}

volumes:
  db_data:
  wordpress_data:
  verifier_data:
