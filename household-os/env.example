POSTGRES_DB=vikunja
POSTGRES_USER=vikunja
POSTGRES_PASSWORD=replace-with-random-db-password

VIKUNJA_HOST_BIND=0.0.0.0
VIKUNJA_HOST_PORT=3456
VIKUNJA_SERVICE_PUBLICURL=http://vikunja.local:3456/
VIKUNJA_SERVICE_SECRET=replace-with-openssl-rand-hex-32
VIKUNJA_SERVICE_TIMEZONE=Europe/Berlin
VIKUNJA_SERVICE_ENABLEREGISTRATION=false
VIKUNJA_SERVICE_ENABLELINKSHARING=false
VIKUNJA_SERVICE_ENABLETASKCOMMENTS=true
# Optional phone-facing link used in notification digests.
VIKUNJA_WEB_URL=http://vikunja.local:3456/

HOUSEHOLD_OS_HOST_BIND=0.0.0.0
HOUSEHOLD_OS_HOST_PORT=8088
HOUSEHOLD_OS_TIMEZONE=Europe/Berlin
HOUSEHOLD_OS_TOKEN=replace-with-random-private-ui-token

# Create this in Vikunja Settings -> API Tokens for a dedicated
# household-assistant user after the household users's shared projects exist.
VIKUNJA_TOKEN=tk_replace_with_scoped_vikunja_api_token

HOMEASSISTANT_URL=http://homeassistant.local:8123
HOMEASSISTANT_TOKEN=replace-with-dedicated-home-assistant-long-lived-token

OPENCLAW_GATEWAY_URL=http://openclaw.local:18789
OPENCLAW_GATEWAY_TOKEN=replace-with-openclaw-gateway-token

# Optional AgentCart bridge for the local demo chat flow.
AGENTCART_URL=http://agentcart.local:8099
AGENTCART_TOKEN=replace-with-agentcart-token
AGENTCART_APPROVAL_WAIT_SECONDS=180

# Use either a notify group, or both mobile_app services.
HA_NOTIFY_SERVICES=notify.mobile_app_demo_phone,notify.mobile_app_partner_phone
HA_SHOPPING_TODO_ENTITY=todo.einkaufsliste

# Replace these after the SwitchBot CO2 sensor and window entities are named.
HA_CO2_ENTITY_IDS=sensor.living_room_co2,sensor.bedroom_co2
HA_WINDOW_ENTITY_IDS=binary_sensor.living_room_window,binary_sensor.bedroom_window
HA_CO2_THRESHOLD_PPM=1000

# Only scripts listed here can be triggered through Household OS.
HA_ALLOWED_SCRIPT_IDS=script.household_lueften_reminder,script.household_weekend_reset

# Optional private iCalendar feed for neutral cycle-support windows.
# Keep this token private; iPhone Calendar subscriptions can use this tokenized URL
# without a Household OS browser session cookie.
CYCLE_CALENDAR_ENABLED=false
CYCLE_CALENDAR_TOKEN=replace-with-random-calendar-token
CYCLE_CALENDAR_START_DATE=2026-06-04
CYCLE_CALENDAR_LENGTH_DAYS=28
CYCLE_CALENDAR_PERIOD_DAYS=5
CYCLE_CALENDAR_MONTHS_AHEAD=6

# Optional private iCalendar feed for open Vikunja task due dates.
# If TASK_CALENDAR_TOKEN is empty, the bridge falls back to CYCLE_CALENDAR_TOKEN.
TASK_CALENDAR_ENABLED=false
TASK_CALENDAR_TOKEN=
TASK_CALENDAR_DAYS_PAST=14
TASK_CALENDAR_DAYS_AHEAD=180
TASK_CALENDAR_EVENT_MINUTES=30
